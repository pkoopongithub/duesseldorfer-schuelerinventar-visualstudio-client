<Window x:Class="DueskWPF.Views.TimeSeriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Zeitreihenanalyse" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,15" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Zeitreihenanalyse" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="GroupNameText" FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Competence Selector -->
        <Border Grid.Row="1" Background="White" Padding="15" Margin="0,0,0,15" CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Kompetenz auswählen:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ComboBox x:Name="CompetenceCombo" Width="200" Margin="15,0,0,0" 
                          SelectionChanged="CompetenceCombo_SelectionChanged"/>
            </StackPanel>
        </Border>
        
        <!-- Chart and Table -->
        <Border Grid.Row="2" Background="White" Padding="15" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="350"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Entwicklung über Profile" FontWeight="Bold" FontSize="14"/>
                
                <lvc:CartesianChart x:Name="TimeSeriesChart" Grid.Row="1" Margin="0,10,0,10"/>
                
                <TextBlock Grid.Row="2" Text="Detailtabelle" FontWeight="Bold" FontSize="14" Margin="0,10,0,10"/>
                
                <DataGrid x:Name="DataTable" Grid.Row="3" AutoGenerateColumns="True" 
                          IsReadOnly="True" RowHeight="25"/>
            </Grid>
        </Border>
    </Grid>
</Window>