<Window x:Class="DueskWPF.Views.GroupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gruppenverwaltung" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Add Group -->
        <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,15" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Neue Gruppe" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewGroupBox" Grid.Column="0" Padding="8"/>
                    <Button x:Name="AddButton" Grid.Column="1" Content="Hinzufügen" 
                            Width="100" Margin="10,0,0,0" Padding="8"
                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="AddButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <!-- Group List -->
        <Border Grid.Row="1" Background="White" Padding="10" CornerRadius="8">
            <ListBox x:Name="GroupListBox" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="14"/>
                                <Button Grid.Column="1" Content="🗑️ Löschen" 
                                        Tag="{Binding GruppeID}"
                                        Click="DeleteButton_Click"
                                        Background="#FAA" BorderThickness="0"
                                        Padding="8,4" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        
        <!-- Close Button -->
        <Button Grid.Row="2" Content="Schließen" Width="100" 
                Margin="0,15,0,0" Padding="8" HorizontalAlignment="Right"
                Background="#F0F0F0" BorderThickness="0" Cursor="Hand"
                Click="CloseButton_Click"/>
    </Grid>
</Window>